---
interface Props {
  title: string;
  description: string;
  slug?: string;
  canonicalPath?: string;
  ogImage?: string;
}

const { title, description, slug, canonicalPath, ogImage } = Astro.props;
const siteBase = Astro.site?.href || 'https://korean-slang.pages.dev';
const canonicalURL = new URL(canonicalPath ?? (slug ? `/slang/${slug}` : '/'), siteBase);
const ogImageURL = ogImage ?? `${siteBase}favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="Xzcbj94NGAqHe0cnPv347Lpm2MdB0B-Juj2HQlOp4OQ" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph (소셜 공유용) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2991825493981285" crossorigin="anonymous"></script>

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M7JM1TTP8B"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-M7JM1TTP8B');
    </script>

    <style is:global>
      :root {
        --color-bg: #FAF9F6;
        --color-surface: #FFFFFF;
        --color-text: #1A1A1A;
        --color-text-muted: #6B7280;
        --color-accent: #E8453C;
        --color-accent-hover: #D03A32;
        --color-tag-bg: #F3F4F6;
        --color-tag-text: #4B5563;
        --color-border: #E5E7EB;
        --color-korean: #1A1A1A;
        --font-display: 'Plus Jakarta Sans', sans-serif;
        --font-korean: 'Noto Sans KR', sans-serif;
        --radius: 12px;
        --max-w: 960px;
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-display);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-icon">한</span>
          <span class="logo-text">KoreanSlang<span class="logo-dot">.guide</span></span>
        </a>
        <nav class="nav">
          <a href="/#categories">Categories</a>
          <a href="/blog">Blog</a>
          <a href="/#submit-section" class="nav-submit">
            Submit a word →
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p>Made for learners, fans & expats who want to understand real Korean.</p>
        <p class="footer-sub">© 2026 KoreanSlang.guide · <a href="/#submit-section">Submit a word</a></p>
      </div>
    </footer>

    <style>
      .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(250, 249, 246, 0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
      }
      .header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0.875rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.625rem;
      }
      .logo-icon {
        font-family: var(--font-korean);
        font-weight: 900;
        font-size: 1.25rem;
        background: var(--color-accent);
        color: white;
        width: 2rem;
        height: 2rem;
        border-radius: 8px;
        display: grid;
        place-items: center;
      }
      .logo-text {
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: -0.02em;
      }
      .logo-dot { color: var(--color-accent); }
      .nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-text-muted);
      }
      .nav a:hover { color: var(--color-text); }
      .nav-submit {
        background: var(--color-text);
        color: white !important;
        padding: 0.4rem 0.875rem;
        border-radius: 999px;
        font-size: 0.8rem;
      }
      .nav-submit:hover { background: var(--color-accent) !important; }

      .footer {
        margin-top: 5rem;
        padding: 2.5rem 1.5rem;
        text-align: center;
        border-top: 1px solid var(--color-border);
        color: var(--color-text-muted);
        font-size: 0.875rem;
      }
      .footer-inner { max-width: var(--max-w); margin: 0 auto; }
      .footer-sub { margin-top: 0.5rem; font-size: 0.75rem; }
      .footer a { text-decoration: underline; }

      @media (max-width: 640px) {
        .nav a:not(.nav-submit) { display: none; }
        .logo-text { font-size: 0.9rem; }
      }
    </style>
  </body>
</html>

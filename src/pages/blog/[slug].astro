---
import Layout from '../../layouts/Layout.astro';
import SlangCard from '../../components/SlangCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { posts } from '../../data/posts';
import { slangData } from '../../data/slang';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const relatedSlang = post.relatedSlugs
  ? slangData.filter((s) => post.relatedSlugs!.includes(s.slug))
  : [];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,
  "datePublished": post.publishedAt,
  "dateModified": post.publishedAt,
  "author": {
    "@type": "Organization",
    "name": "KoreanSlang.guide",
    "url": "https://korean-slang.pages.dev"
  },
  "publisher": {
    "@type": "Organization",
    "name": "KoreanSlang.guide",
    "logo": {
      "@type": "ImageObject",
      "url": "https://korean-slang.pages.dev/favicon.svg"
    }
  },
  "image": post.ogImage,
  "url": `https://korean-slang.pages.dev/blog/${post.slug}`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<Layout
  title={`${post.title} | KoreanSlang.guide`}
  description={post.description}
  canonicalPath={`/blog/${post.slug}`}
  ogImage={post.ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <article class="post">
    <!-- Hero Image -->
    <div class="post-hero">
      <img
        src={post.heroImage}
        alt={post.heroImageAlt}
        width="1200"
        height="400"
        class="post-hero-img"
      />
      <div class="post-hero-overlay">
        <span class="post-hero-category">{post.category}</span>
      </div>
    </div>

    <div class="post-inner">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Home</a> <span>/</span>
        <a href="/blog">Blog</a> <span>/</span>
        <span>{post.title}</span>
      </nav>

      <header class="post-header">
        <p class="post-date">{new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <h1 class="post-title">{post.title}</h1>
        <p class="post-description">{post.description}</p>
      </header>

      <!-- Ad slot above content -->
      <AdSlot slot="blog-top" style="display:block;margin:1.5rem 0;" />

      <!-- Post content -->
      <div class="post-content" set:html={post.content} />

      <!-- Ad slot mid-content -->
      <AdSlot slot="blog-mid" style="display:block;margin:2rem 0;" />

      <!-- FAQ Section -->
      <section class="faq-section">
        <h2 class="faq-heading">Frequently Asked Questions</h2>
        <div class="faq-list">
          {post.faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-question">{faq.question}</summary>
              <p class="faq-answer">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related slang -->
      {relatedSlang.length > 0 && (
        <section class="related-section">
          <h2 class="related-heading">Explore Related Slang</h2>
          <div class="related-grid">
            {relatedSlang.map((s) => (
              <SlangCard
                term={s.term}
                meaning={s.meaning}
                pronunciation={s.pronunciation}
                slug={s.slug}
                category={s.category}
              />
            ))}
          </div>
        </section>
      )}

      <!-- Ad slot bottom -->
      <AdSlot slot="blog-bottom" style="display:block;margin:2rem 0;" />

      <a href="/blog" class="back-link">← All guides</a>
    </div>
  </article>
</Layout>

<style>
  /* Hero */
  .post-hero {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
  }
  .post-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-hero-overlay {
    position: absolute;
    bottom: 1rem;
    left: 1.5rem;
  }
  .post-hero-category {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-accent);
    color: white;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }

  /* Layout */
  .post { padding-bottom: 4rem; }
  .post-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
  }

  .breadcrumb {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .breadcrumb a:hover { color: var(--color-accent); }

  /* Header */
  .post-header { margin-bottom: 2rem; }
  .post-date {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .post-title {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .post-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }

  /* Content typography */
  .post-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 2.25rem 0 0.75rem;
    line-height: 1.3;
  }
  .post-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 1.75rem 0 0.5rem;
  }
  .post-content :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 1.1rem;
  }
  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .post-content :global(li) {
    font-size: 0.975rem;
    line-height: 1.7;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .post-content :global(strong) { font-weight: 700; }
  .post-content :global(a) {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-content :global(a:hover) { color: var(--color-accent-hover); }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--color-surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
  .post-content :global(.post-figure) {
    margin: 2rem 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .post-content :global(.post-figure img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .post-content :global(.post-figure figcaption) {
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    background: var(--color-surface);
    text-align: center;
    font-style: italic;
  }

  /* FAQ */
  .faq-section { margin: 3rem 0; }
  .faq-heading {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq-item[open] { border-color: var(--color-accent); }
  .faq-question {
    font-size: 0.95rem;
    font-weight: 700;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .faq-item[open] .faq-question::after {
    content: '−';
  }
  .faq-answer {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    padding: 0 1.25rem 1rem;
  }

  /* Related slang */
  .related-section { margin: 3rem 0; }
  .related-heading {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .back-link:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .post-hero { height: 200px; }
    .post-inner { padding: 1rem 1rem 0; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import SlangCard from '../../components/SlangCard.astro';
import { slangData, categories } from '../../data/slang';

// Astro가 빌드 시 모든 슬랭 페이지를 자동 생성
export function getStaticPaths() {
  return slangData.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const category = categories.find((c) => c.id === item.category);

// 같은 카테고리에서 관련 단어 추천 (본인 제외, 최대 4개)
const related = slangData
  .filter((s) => s.category === item.category && s.slug !== item.slug)
  .slice(0, 4);
---

<Layout
  title={`${item.term} meaning — ${item.meaning} | Korean Slang Guide`}
  description={`${item.term} (${item.pronunciation}) means "${item.meaning}" in Korean texting. ${item.description}`}
  slug={item.slug}
>
  <article class="detail">
    <div class="detail-inner">
      <!-- Breadcrumb (SEO용) -->
      <nav class="breadcrumb">
        <a href="/">Home</a> <span>/</span>
        <a href={`/#categories`}>{category?.name}</a> <span>/</span>
        <span>{item.term}</span>
      </nav>

      <!-- Hero -->
      <div class="detail-hero">
        <span class="detail-term">{item.term}</span>
        <span class="detail-pronunciation">/{item.pronunciation}/</span>
      </div>

      <h1 class="detail-meaning">{item.meaning}</h1>
      <p class="detail-desc">{item.description}</p>

      <!-- Examples -->
      <section class="section">
        <h2 class="section-title">Examples</h2>
        <div class="examples">
          {item.examples.map((ex: { ko: string; en: string }) => (
            <div class="example">
              <p class="example-ko">{ex.ko}</p>
              <p class="example-en">{ex.en}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Copy button -->
      <button class="copy-btn" id="copy-btn" data-term={item.term}>
        📋 Copy "{item.term}" to clipboard
      </button>

      <!-- Tags -->
      <div class="tags">
        {item.tags.map((tag: string) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>

      <!-- Related -->
      {related.length > 0 && (
        <section class="section">
          <h2 class="section-title">Related</h2>
          <div class="related-grid">
            {related.map((r) => (
              <SlangCard
                term={r.term}
                meaning={r.meaning}
                pronunciation={r.pronunciation}
                slug={r.slug}
                category={r.category}
              />
            ))}
          </div>
        </section>
      )}

      <a href="/" class="back-link">← Browse all words</a>
    </div>
  </article>
</Layout>

<!-- Copy to clipboard -->
<script>
  const btn = document.getElementById('copy-btn') as HTMLButtonElement;
  btn.addEventListener('click', async () => {
    const term = btn.dataset.term || '';
    await navigator.clipboard.writeText(term);
    gtag('event', 'slang_copy', { slang_term: term });
    btn.textContent = '✅ Copied!';
    setTimeout(() => {
      btn.textContent = `📋 Copy "${term}" to clipboard`;
    }, 1500);
  });
</script>

<style>
  .detail { padding: 1.5rem; }
  .detail-inner { max-width: 640px; margin: 0 auto; }

  .breadcrumb {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .breadcrumb a:hover { color: var(--color-accent); }

  .detail-hero {
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .detail-term {
    font-family: var(--font-korean);
    font-weight: 900;
    font-size: clamp(4rem, 12vw, 7rem);
    color: var(--color-korean);
    line-height: 1.1;
    display: block;
  }
  .detail-pronunciation {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .detail-meaning {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-accent);
    margin: 0.75rem 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .detail-desc {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto 2rem;
  }

  .section { margin: 2.5rem 0; }
  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .examples { display: flex; flex-direction: column; gap: 0.75rem; }
  .example {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }
  .example-ko {
    font-family: var(--font-korean);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .example-en {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .copy-btn {
    display: block;
    width: 100%;
    padding: 0.75rem;
    margin: 1.5rem 0;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius);
    background: transparent;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }
  .copy-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 1rem 0;
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: 999px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .back-link:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .detail { padding: 1rem; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import SlangCard from '../components/SlangCard.astro';
import { slangData, categories } from '../data/slang';

const popularFirst = [...slangData].sort((a, b) => b.popularity - a.popularity);
---

<Layout
  title="Korean Slang Guide — Decode Real Korean Texting"
  description="Learn what ㅋㅋ, ㅠㅠ, ㄹㅇ and other Korean slang actually mean. A simple guide for K-pop fans, learners, and expats."
>
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-tag">🇰🇷 The Korean Texting Dictionary</p>
      <h1 class="hero-title">
        What does <span class="hero-highlight">ㅋㅋ</span> mean?
      </h1>
      <p class="hero-sub">
        Decode Korean texts, DMs, and comments.<br />
        Built for learners, K-pop fans & expats.
      </p>
      <div class="search-wrap">
        <input
          type="text"
          id="search"
          class="search-input"
          placeholder="Search: ㅋㅋ, ㅠㅠ, daebak, lol..."
          autocomplete="off"
        />
      </div>
    </div>
  </section>

  <section class="content" id="categories">
    <div class="content-inner">
      <!-- Category filter -->
      <div class="filters">
        <button class="filter-btn active" data-filter="all">All</button>
        {categories.map((cat) => (
          <button class="filter-btn" data-filter={cat.id}>
            {cat.icon} {cat.name}
          </button>
        ))}
      </div>

      <!-- Slang grid -->
      <div class="grid" id="slang-grid">
        {popularFirst.map((item) => (
          <SlangCard
            term={item.term}
            meaning={item.meaning}
            pronunciation={item.pronunciation}
            slug={item.slug}
            category={item.category}
          />
        ))}
      </div>

      <p class="no-results" id="no-results" style="display: none;">
        No results found. <a href="https://forms.gle/YOUR_FORM_ID" target="_blank">Submit this word →</a>
      </p>
    </div>
  </section>

  <section class="submit-section">
    <div class="submit-inner">
      <h2 class="submit-title">모르는 단어가 있나요?</h2>
      <p class="submit-desc">직접 제보해주시면 검토 후 사전에 추가할게요.</p>
      <form class="submit-form" id="submit-form">
        <div class="form-field">
          <label for="f-term">단어 *</label>
          <input type="text" id="f-term" name="term" placeholder="예: ㅇㅈ" required />
        </div>
        <div class="form-field">
          <label for="f-meaning">뜻 *</label>
          <input type="text" id="f-meaning" name="meaning" placeholder="예: 인정 (I agree / Fair enough)" required />
        </div>
        <div class="form-field">
          <label for="f-example">예시 문장</label>
          <input type="text" id="f-example" name="example" placeholder="예: ㅇㅈ? ㅇ ㅇㅈ" />
        </div>
        <button type="submit" class="submit-btn" id="submit-btn">제보하기 →</button>
      </form>
      <p class="submit-success" id="submit-success" style="display: none;">
        제보해줘서 고마워요! 검토 후 반영할게요 🙏
      </p>
    </div>
  </section>
</Layout>

<!-- Client-side search & filter (vanilla JS, 가벼움) -->
<script>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const grid = document.getElementById('slang-grid')!;
  const cards = Array.from(grid.querySelectorAll('.card')) as HTMLElement[];
  const filterBtns = document.querySelectorAll('.filter-btn');
  const noResults = document.getElementById('no-results')!;

  let activeFilter = 'all';

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const term = card.querySelector('.card-term')?.textContent?.toLowerCase() || '';
      const meaning = card.querySelector('.card-meaning')?.textContent?.toLowerCase() || '';
      const category = card.dataset.category || '';

      const matchesSearch = !query || term.includes(query) || meaning.includes(query);
      const matchesFilter = activeFilter === 'all' || category === activeFilter;

      const show = matchesSearch && matchesFilter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.style.display = visible === 0 ? '' : 'none';
  }

  let searchDebounce: ReturnType<typeof setTimeout>;
  searchInput.addEventListener('input', () => {
    applyFilters();
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => {
      const q = searchInput.value.trim();
      if (q) gtag('event', 'search', { search_term: q });
    }, 600);
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = (btn as HTMLElement).dataset.filter || 'all';
      applyFilters();
    });
  });

  // ↓ Apps Script 배포 후 URL로 교체
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwdQJc68DDbgW3os-23awT13l5dm7Cchfe9wUoGRdzhpKtDVWkFMlExLlsFyiZCUJ657Q/exec';

  const submitForm = document.getElementById('submit-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitSuccess = document.getElementById('submit-success')!;

  submitForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = '제출 중...';

    const body = {
      term: (document.getElementById('f-term') as HTMLInputElement).value.trim(),
      meaning: (document.getElementById('f-meaning') as HTMLInputElement).value.trim(),
      example: (document.getElementById('f-example') as HTMLInputElement).value.trim(),
    };

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        body: JSON.stringify(body),
      });
      submitForm.style.display = 'none';
      submitSuccess.style.display = '';
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = '제보하기 →';
      alert('오류가 발생했어요. 잠시 후 다시 시도해주세요.');
    }
  });

  grid.addEventListener('click', (e) => {
    const card = (e.target as Element).closest('.card') as HTMLElement | null;
    if (!card) return;
    const term = card.querySelector('.card-term')?.textContent?.trim() || '';
    if (term) gtag('event', 'slang_view', { slang_term: term });
  });
</script>

<style>
  /* Hero */
  .hero {
    padding: 4rem 1.5rem 2.5rem;
    text-align: center;
  }
  .hero-inner { max-width: var(--max-w); margin: 0 auto; }
  .hero-tag {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }
  .hero-highlight {
    font-family: var(--font-korean);
    color: var(--color-accent);
  }
  .hero-sub {
    margin-top: 0.75rem;
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Search */
  .search-wrap {
    max-width: 480px;
    margin: 1.75rem auto 0;
  }
  .search-input {
    width: 100%;
    padding: 0.875rem 1.25rem;
    font-size: 1rem;
    font-family: var(--font-display);
    border: 2px solid var(--color-border);
    border-radius: 999px;
    outline: none;
    background: var(--color-surface);
    transition: border-color 0.2s;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-input::placeholder { color: #B0B0B0; }

  /* Content */
  .content { padding: 0 1.5rem 3rem; }
  .content-inner { max-width: var(--max-w); margin: 0 auto; }

  /* Filters */
  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .filter-btn {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--color-text); color: var(--color-text); }
  .filter-btn.active {
    background: var(--color-text);
    color: white;
    border-color: var(--color-text);
  }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  /* No results */
  .no-results {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .no-results a {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Submit section */
  .submit-section {
    padding: 3rem 1.5rem 4rem;
    border-top: 1px solid var(--color-border);
  }
  .submit-inner {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }
  .submit-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }
  .submit-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
  }
  .submit-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    text-align: left;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .form-field label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .form-field input {
    font-family: var(--font-display);
    font-size: 0.95rem;
    padding: 0.65rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    outline: none;
    transition: border-color 0.15s;
  }
  .form-field input:focus { border-color: var(--color-accent); }
  .submit-btn {
    margin-top: 0.25rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.7rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    align-self: flex-end;
    transition: background 0.15s;
  }
  .submit-btn:hover:not(:disabled) { background: var(--color-accent-hover); }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .submit-success {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius);
    margin-top: 0.5rem;
  }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 1.25rem 1.5rem; }
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

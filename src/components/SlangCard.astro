---
interface Props {
  term: string;
  meaning: string;
  pronunciation: string;
  slug: string;
  category: string;
}

const { term, meaning, pronunciation, slug, category } = Astro.props;
---

<a href={`/slang/${slug}`} class="card" data-category={category}>
  <span class="card-term">{term}</span>
  <span class="card-pronunciation">/{pronunciation}/</span>
  <span class="card-meaning">{meaning}</span>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-align: center;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232, 69, 60, 0.08);
  }
  .card-term {
    font-family: var(--font-korean);
    font-weight: 900;
    font-size: 2rem;
    color: var(--color-korean);
    line-height: 1.2;
  }
  .card-pronunciation {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .card-meaning {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }
</style>
